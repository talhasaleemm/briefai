# BriefAI Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── App Settings ───────────────────────────────────────────────────────────────
APP_NAME=BriefAI
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Whisper Settings ───────────────────────────────────────────────────────────
# Model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL_SIZE=base
# Device: cpu or cuda (set cuda if you have an NVIDIA GPU)
WHISPER_DEVICE=cpu
# Compute type: int8 (CPU), float16 (CUDA), float32 (fallback)
WHISPER_COMPUTE_TYPE=int8
# Language: auto-detect if left empty, or set e.g. "en", "fr", "ar"
WHISPER_LANGUAGE=

# ── Ollama Settings ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Default models (must be pulled via scripts/pull_models.ps1)
OLLAMA_SUMMARIZER_MODEL=qwen3:1.7b
OLLAMA_TRANSLATOR_MODEL=llama3.2:1b
# Timeout in seconds for Ollama API calls
OLLAMA_TIMEOUT=120

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
